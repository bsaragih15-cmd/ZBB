# Copy to .env.local for local dev (gitignored). Production values live in
# .env.production (publishable key is safe to commit; Supabase RLS enforces access).

# Supabase project (https://<ref>.supabase.co) and publishable/anon key
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# Server-only (Vercel env var, NOT prefixed with VITE_ so it never reaches the client).
# Required by the /api/copilot AI function. Get one at https://console.anthropic.com
ANTHROPIC_API_KEY=
